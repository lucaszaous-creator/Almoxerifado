# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase.
# Painel Supabase > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# (Opcional) Pesquisa de preços com resultados dentro do app, via
# Google Programmable Search (Custom Search JSON API).
# Sem estas variáveis, a pesquisa ainda funciona abrindo o Google em nova aba.
# Crie em: https://programmablesearchengine.google.com (CX) e
# https://console.cloud.google.com (API key da "Custom Search API").
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
