<Window x:Class="ALMOXPRO.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ALMOXPRO.UI.ViewModels"
        Title="ALMOX PRO - Gestão de Almoxarifado"
        Height="800" Width="1360"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource MaterialDesignBackground}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,1,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="240" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                            <Setter Property="Width" Value="64" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,16,12,20">
                    <materialDesign:PackIcon Kind="Warehouse" Width="32" Height="32"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="ALMOX PRO" FontSize="18" FontWeight="Bold" Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem}"
                         Style="{StaticResource MaterialDesignNavigationPrimaryListBox}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NavItem}">
                            <StackPanel Orientation="Horizontal" ToolTip="{Binding Label}">
                                <materialDesign:PackIcon Kind="{Binding Icon}" Width="22" Height="22"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Label}" Margin="14,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.IsSidebarExpanded,
                                                        RelativeSource={RelativeSource AncestorType=Window},
                                                        Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Área principal -->
        <DockPanel Grid.Column="1">
            <!-- Barra superior -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource MaterialDesignPaper}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1"
                    Height="56">
                <DockPanel LastChildFill="False" Margin="8,0">
                    <Button DockPanel.Dock="Left" Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding ToggleSidebarCommand}" ToolTip="Recolher/expandir menu">
                        <materialDesign:PackIcon Kind="Menu" />
                    </Button>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding Breadcrumb}"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="14" Opacity="0.8" />

                    <materialDesign:PopupBox DockPanel.Dock="Right" PlacementMode="BottomAndAlignRightEdges"
                                             Margin="4,0,8,0" VerticalAlignment="Center">
                        <materialDesign:PopupBox.ToggleContent>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountCircle" Width="28" Height="28"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding UserName}" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </materialDesign:PopupBox.ToggleContent>
                        <StackPanel MinWidth="180">
                            <Button Content="Alterar senha" Command="{Binding ChangePasswordCommand}" />
                            <Separator />
                            <Button Content="Sair (logoff)"
                                    Command="{Binding LogoffCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                    </materialDesign:PopupBox>

                    <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding ToggleThemeCommand}" ToolTip="Alternar tema claro/escuro"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ThemeLightDark" />
                    </Button>

                    <!-- Notificação de atualização disponível -->
                    <Button DockPanel.Dock="Right" Margin="0,0,4,0" VerticalAlignment="Center"
                            Background="#2E7D32" BorderBrush="#2E7D32"
                            Command="{Binding InstallUpdateCommand}"
                            Visibility="{Binding AvailableUpdate, Converter={StaticResource NotNullToVis}}"
                            IsEnabled="{Binding IsUpdating, Converter={StaticResource InverseBool}}"
                            ToolTip="Baixar e instalar a nova versão. Configurações e banco são preservados.">
                        <StackPanel Orientation="Horizontal">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         IsIndeterminate="True" Width="16" Height="16" Margin="0,0,6,0"
                                         Foreground="White"
                                         Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}" />
                            <materialDesign:PackIcon Kind="Download" VerticalAlignment="Center"
                                                     Visibility="{Binding IsUpdating, Converter={StaticResource InverseBoolToVis}}" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">
                                <Run Text="ATUALIZAR PARA " /><Run Text="{Binding AvailableUpdate.TagName, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Conteúdo -->
            <Grid>
                <ContentControl Content="{Binding CurrentViewModel}" Margin="16" />
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True" Width="48" Height="48"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Visibility="{Binding CurrentViewModel.IsBusy,
                                          Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" />
            </Grid>
        </DockPanel>
    </Grid>
</Window>
