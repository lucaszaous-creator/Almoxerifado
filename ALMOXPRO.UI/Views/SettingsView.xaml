<UserControl x:Class="ALMOXPRO.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <WrapPanel>
            <WrapPanel.Resources>
                <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                    <Setter Property="Margin" Value="0,0,0,12" />
                </Style>
            </WrapPanel.Resources>

            <!-- Empresa -->
            <materialDesign:Card Width="420" Margin="0,0,16,16" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="Domain" VerticalAlignment="Center" Width="24" Height="24" />
                        <TextBlock Text="Empresa" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox materialDesign:HintAssist.Hint="Razão Social" Text="{Binding CompanyName}"
                             IsEnabled="{Binding CanManage}" />
                    <TextBox materialDesign:HintAssist.Hint="CNPJ" Text="{Binding CompanyCnpj}"
                             IsEnabled="{Binding CanManage}" />
                    <TextBox materialDesign:HintAssist.Hint="Caminho do logo" Text="{Binding LogoPath}"
                             IsEnabled="{Binding CanManage}" />
                    <TextBox materialDesign:HintAssist.Hint="Bloqueio por inatividade (minutos, 0 desativa)"
                             Text="{Binding SessionTimeoutMinutes}" IsEnabled="{Binding CanManage}"
                             ToolTip="Encerra a sessão automaticamente após esse tempo sem uso. Vale a partir do próximo login." />
                </StackPanel>
            </materialDesign:Card>

            <!-- Backup -->
            <materialDesign:Card Width="420" Margin="0,0,16,16" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="DatabaseExport" VerticalAlignment="Center" Width="24" Height="24" />
                        <TextBlock Text="Backup do banco de dados" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox materialDesign:HintAssist.Hint="Diretório de backup" Text="{Binding BackupDirectory}"
                             IsEnabled="{Binding CanManage}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Caminho do pg_dump"
                                 Text="{Binding PgDumpPath}" IsEnabled="{Binding CanManage}" />
                        <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Caminho do pg_restore"
                                 Text="{Binding PgRestorePath}" IsEnabled="{Binding CanManage}" />
                    </Grid>
                    <CheckBox Content="Compactar backup (zip)" IsChecked="{Binding BackupCompress}"
                              IsEnabled="{Binding CanManage}" Margin="0,0,0,8" />
                    <CheckBox Content="Backup automático diário (executa em segundo plano durante o uso)"
                              IsChecked="{Binding BackupAutoEnabled}"
                              IsEnabled="{Binding CanManage}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding BackupNowCommand}" Margin="0,0,8,0"
                                Visibility="{Binding CanBackup, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" />
                                <TextBlock Text="BACKUP AGORA" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RestoreCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Visibility="{Binding CanRestore, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseImport" VerticalAlignment="Center" />
                                <TextBlock Text="RESTAURAR" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Almoxarifados -->
            <materialDesign:Card Width="420" Margin="0,0,16,16" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="Warehouse" VerticalAlignment="Center" Width="24" Height="24" />
                        <TextBlock Text="Almoxarifados" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Warehouses}" MaxHeight="160" Margin="0,0,0,12"
                             SelectedItem="{Binding SelectedWarehouse, Mode=OneWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectWarehouseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                      CommandParameter="{Binding}" />
                                    </TextBlock.InputBindings>
                                    <Run Text="{Binding Code, Mode=OneWay}" FontWeight="SemiBold" />
                                    <Run Text=" — " />
                                    <Run Text="{Binding Name, Mode=OneWay}" />
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Código"
                                 Text="{Binding WarehouseCode}" IsEnabled="{Binding CanManage}" />
                        <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Nome"
                                 Text="{Binding WarehouseName}" IsEnabled="{Binding CanManage}" />
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="NOVO" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding NewWarehouseCommand}" Margin="0,0,8,0"
                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}" />
                        <Button Content="SALVAR ALMOXARIFADO" Command="{Binding SaveWarehouseCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Fiscal (NF-e) -->
            <materialDesign:Card Width="420" Margin="0,0,16,16" Padding="20"
                                 Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="FileCertificateOutline" VerticalAlignment="Center" Width="24" Height="24" />
                        <TextBlock Text="Fiscal (NF-e / SEFAZ)" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding FiscalCertStatus}" TextWrapping="Wrap" Margin="0,0,0,12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="CNPJ da empresa *"
                                 Text="{Binding FiscalCnpj}" />
                        <ComboBox Grid.Column="2" materialDesign:HintAssist.Hint="UF *"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding Ufs}" SelectedItem="{Binding FiscalUf}"
                                  Margin="0,0,0,12" />
                    </Grid>
                    <CheckBox Content="Ambiente de produção (desmarque para testes em homologação)"
                              IsChecked="{Binding FiscalProduction}" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding SelectFiscalCertificateCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Upload" VerticalAlignment="Center" />
                                <TextBlock Text="CERTIFICADO A1" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                        <TextBlock Grid.Column="2" Text="{Binding FiscalCertFileName}" VerticalAlignment="Center"
                                   Opacity="0.7" TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <TextBox materialDesign:HintAssist.Hint="Senha do certificado"
                             Text="{Binding FiscalCertPassword, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,12,0,12" />
                    <Button Content="SALVAR CONFIGURAÇÃO FISCAL" Command="{Binding SaveFiscalConfigCommand}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Banco de dados -->
            <materialDesign:Card Width="420" Margin="0,0,16,16" Padding="20"
                                 Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="Database" VerticalAlignment="Center" Width="24" Height="24" />
                        <TextBlock Text="Banco de dados" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Troque o servidor PostgreSQL (local, rede ou nuvem como Neon/Supabase). A alteração vale após reabrir o sistema."
                               TextWrapping="Wrap" Margin="0,0,0,12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    <Button Content="TROCAR CONEXÃO DO BANCO" Command="{Binding ChangeDatabaseConnectionCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalAlignment="Left" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Salvar -->
            <materialDesign:Card Width="420" Margin="0,0,16,16" Padding="20"
                                 Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="ContentSaveSettings" VerticalAlignment="Center" Width="24" Height="24" />
                        <TextBlock Text="Aplicar configurações" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Grava os parâmetros de empresa e backup no banco de dados."
                               TextWrapping="Wrap" Margin="0,0,0,12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    <Button Content="SALVAR CONFIGURAÇÕES" Command="{Binding SaveSettingsCommand}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </materialDesign:Card>
        </WrapPanel>
    </ScrollViewer>
</UserControl>
