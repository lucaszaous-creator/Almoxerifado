<UserControl x:Class="ALMOXPRO.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Cartões de indicadores -->
            <UniformGrid Columns="7" Margin="0,0,0,16">
                <UniformGrid.Resources>
                    <Style TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
                        <Setter Property="Margin" Value="0,0,12,0" />
                        <Setter Property="Padding" Value="16" />
                    </Style>
                </UniformGrid.Resources>

                <materialDesign:Card Cursor="Hand" ToolTip="Abrir cadastro de produtos">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenProductsCommand}" />
                    </materialDesign:Card.InputBindings>
                    <StackPanel>
                        <TextBlock Text="Produtos" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Data.TotalProducts, FallbackValue=0}" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Cursor="Hand" ToolTip="Abrir relatório de valor em estoque">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenReportCommand}" CommandParameter="ValorEmEstoque" />
                    </materialDesign:Card.InputBindings>
                    <StackPanel>
                        <TextBlock Text="Valor do estoque" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Data.StockTotalValue, StringFormat=C2, FallbackValue=0}" FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Cursor="Hand" ToolTip="Abrir relatório de entradas">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenReportCommand}" CommandParameter="Entradas" />
                    </materialDesign:Card.InputBindings>
                    <StackPanel>
                        <TextBlock Text="Entradas hoje" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Data.EntriesToday, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                   Foreground="#2E7D32" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Cursor="Hand" ToolTip="Abrir relatório de saídas">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenReportCommand}" CommandParameter="Saidas" />
                    </materialDesign:Card.InputBindings>
                    <StackPanel>
                        <TextBlock Text="Saídas hoje" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Data.ExitsToday, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                   Foreground="#C62828" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Cursor="Hand" ToolTip="Abrir relatório de estoque mínimo">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenReportCommand}" CommandParameter="EstoqueMinimo" />
                    </materialDesign:Card.InputBindings>
                    <StackPanel>
                        <TextBlock Text="Abaixo do mínimo" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Data.BelowMinimum, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                   Foreground="#EF6C00" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Cursor="Hand" ToolTip="Abrir relatório de produtos vencidos e a vencer">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenReportCommand}" CommandParameter="ProdutosVencidos" />
                    </materialDesign:Card.InputBindings>
                    <StackPanel>
                        <TextBlock Text="A vencer (30 dias)" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Data.ExpiringSoon, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                   Foreground="#F9A825" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="0" Cursor="Hand" ToolTip="Abrir relatório de produtos vencidos">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenReportCommand}" CommandParameter="ProdutosVencidos" />
                    </materialDesign:Card.InputBindings>
                    <StackPanel>
                        <TextBlock Text="Vencidos" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Data.ExpiredProducts, FallbackValue=0}" FontSize="28" FontWeight="Bold"
                                   Foreground="#C62828" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Curva ABC -->
                <materialDesign:Card Grid.Column="0" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Curva ABC (valor em estoque)" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <DataGrid ItemsSource="{Binding AbcCurve}" AutoGenerateColumns="False"
                                  IsReadOnly="True" MaxHeight="300" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="Valor" Binding="{Binding Value, StringFormat=C2}" Width="110" />
                                <DataGridTextColumn Header="% Acum." Binding="{Binding AccumulatedPercent, StringFormat={}{0:N1}%}" Width="80" />
                                <DataGridTextColumn Header="Classe" Binding="{Binding Class}" Width="60" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Movimentações recentes -->
                <materialDesign:Card Grid.Column="1" Padding="16" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Movimentações recentes" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <DataGrid ItemsSource="{Binding RecentMovements}" AutoGenerateColumns="False"
                                  IsReadOnly="True" MaxHeight="300" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding Date, StringFormat=dd/MM HH:mm}" Width="100" />
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="140" />
                                <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="Qtde" Binding="{Binding Quantity, StringFormat=N2}" Width="80" />
                                <DataGridTextColumn Header="Usuário" Binding="{Binding User}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- Entradas x saídas (30 dias) -->
            <materialDesign:Card Padding="16" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Entradas x Saídas (últimos 30 dias)" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Chart}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,0" VerticalAlignment="Bottom" ToolTip="{Binding Label}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="120">
                                        <Border Background="#2E7D32" Width="10" VerticalAlignment="Bottom"
                                                Height="{Binding Entries}" MaxHeight="120" CornerRadius="2,2,0,0" />
                                        <Border Background="#C62828" Width="10" VerticalAlignment="Bottom"
                                                Height="{Binding Exits}" MaxHeight="120" Margin="2,0,0,0" CornerRadius="2,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Label}" FontSize="9" HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Background="#2E7D32" Width="12" Height="12" CornerRadius="2" VerticalAlignment="Center" />
                        <TextBlock Text="Entradas" Margin="6,0,16,0" FontSize="11" />
                        <Border Background="#C62828" Width="12" Height="12" CornerRadius="2" VerticalAlignment="Center" />
                        <TextBlock Text="Saídas" Margin="6,0,0,0" FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
