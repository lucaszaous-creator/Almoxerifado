<UserControl x:Class="ALMOXPRO.UI.Views.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBox Width="280" materialDesign:HintAssist.Hint="Pesquisar por usuário, tela ou registro"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:TextFieldAssist.HasClearButton="True" Margin="0,0,8,8">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchLogsCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <DatePicker Width="150" materialDesign:HintAssist.Hint="De"
                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                        SelectedDate="{Binding From}" Margin="0,0,8,8" />
            <DatePicker Width="150" materialDesign:HintAssist.Hint="Até"
                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                        SelectedDate="{Binding To}" Margin="0,0,8,8" />
            <Button Command="{Binding SearchLogsCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                    VerticalAlignment="Center" Margin="0,0,8,8">
                <materialDesign:PackIcon Kind="Magnify" />
            </Button>
        </WrapPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding PreviousPageCommand}">
                <materialDesign:PackIcon Kind="ChevronLeft" />
            </Button>
            <TextBlock VerticalAlignment="Center" Margin="8,0">
                <Run Text="{Binding Page}" /><Run Text=" / " /><Run Text="{Binding TotalPages}" />
            </TextBlock>
            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NextPageCommand}">
                <materialDesign:PackIcon Kind="ChevronRight" />
            </Button>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data/Hora" Binding="{Binding OccurredAt, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="150" />
                    <DataGridTextColumn Header="Usuário" Binding="{Binding UserName}" Width="140" />
                    <DataGridTextColumn Header="Computador" Binding="{Binding Computer}" Width="120" />
                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="110" />
                    <DataGridTextColumn Header="Tela" Binding="{Binding Screen}" Width="130" />
                    <DataGridTextColumn Header="Ação" Binding="{Binding Action}" Width="100" />
                    <DataGridTextColumn Header="Tabela" Binding="{Binding TableName}" Width="120" />
                    <DataGridTextColumn Header="Registro" Binding="{Binding RecordId}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Detalhe do registro selecionado -->
            <Grid Grid.Row="1" Margin="0,12,0,0" MaxHeight="180"
                  Visibility="{Binding Selected, Converter={StaticResource NotNullToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Valor anterior"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Selected.OldValues, Mode=OneWay}" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Valor novo"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Selected.NewValues, Mode=OneWay}" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
