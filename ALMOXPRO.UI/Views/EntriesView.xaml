<UserControl x:Class="ALMOXPRO.UI.Views.EntriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12" LastChildFill="False">
                <TextBox Width="320" materialDesign:HintAssist.Hint="Pesquisar por número ou documento"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:TextFieldAssist.HasClearButton="True">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchEntriesCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Margin="8,0,0,0" Command="{Binding SearchEntriesCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Magnify" />
                </Button>

                <Button DockPanel.Dock="Right" Command="{Binding NewCommand}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                        <TextBlock Text="NOVA ENTRADA" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding PreviousPageCommand}">
                    <materialDesign:PackIcon Kind="ChevronLeft" />
                </Button>
                <TextBlock VerticalAlignment="Center" Margin="8,0">
                    <Run Text="{Binding Page}" /><Run Text=" / " /><Run Text="{Binding TotalPages}" />
                </TextBlock>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NextPageCommand}">
                    <materialDesign:PackIcon Kind="ChevronRight" />
                </Button>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Número" Binding="{Binding Number}" Width="110" />
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="110" />
                    <DataGridTextColumn Header="Almoxarifado" Binding="{Binding WarehouseName}" Width="*" />
                    <DataGridTextColumn Header="Fornecedor" Binding="{Binding SupplierName}" Width="180" />
                    <DataGridTextColumn Header="Documento" Binding="{Binding DocumentNumber}" Width="120" />
                    <DataGridTextColumn Header="Data" Binding="{Binding EntryDate, StringFormat=dd/MM/yyyy HH:mm}" Width="140" />
                    <DataGridTextColumn Header="Valor Total" Binding="{Binding TotalValue, StringFormat=C2}" Width="110" />
                    <DataGridTextColumn Header="Itens" Binding="{Binding ItemCount}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border HorizontalAlignment="Right" Width="640"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVis}}"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="Nova Entrada de Materiais" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,16" />
                <DockPanel DockPanel.Dock="Bottom" Margin="0,16,0,0" LastChildFill="False">
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                        <Run Text="Total: " /><Run Text="{Binding EditorTotal, Mode=OneWay, StringFormat=C2}" />
                    </TextBlock>
                    <Button DockPanel.Dock="Right" Content="CONFIRMAR ENTRADA" Command="{Binding ConfirmCommand}" />
                    <Button DockPanel.Dock="Right" Content="CANCELAR" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CancelEditCommand}" Margin="0,0,8,0" />
                </DockPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                <Setter Property="Margin" Value="0,0,0,12" />
                            </Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                                <Setter Property="Margin" Value="0,0,0,12" />
                            </Style>
                        </StackPanel.Resources>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" materialDesign:HintAssist.Hint="Tipo de entrada *"
                                      ItemsSource="{Binding EntryTypes}" SelectedItem="{Binding EntryType}" />
                            <ComboBox Grid.Column="2" materialDesign:HintAssist.Hint="Almoxarifado *"
                                      ItemsSource="{Binding Warehouses}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedWarehouse}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" materialDesign:HintAssist.Hint="Fornecedor"
                                      ItemsSource="{Binding Suppliers}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedSupplier}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Documento / Nota Fiscal"
                                     Text="{Binding DocumentNumber}" />
                        </Grid>
                        <TextBox materialDesign:HintAssist.Hint="Observações" Text="{Binding Notes}" />

                        <Separator Margin="0,4,0,12" />
                        <TextBlock Text="Itens" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="Código interno ou código de barras"
                                     Text="{Binding ItemCode, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding FindProductCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2" Command="{Binding FindProductCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                                    Margin="0,0,0,12" ToolTip="Localizar produto">
                                <materialDesign:PackIcon Kind="BarcodeScan" />
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding FoundProduct.Name}" FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Quantidade"
                                     Text="{Binding ItemQuantity}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Custo unitário"
                                     Text="{Binding ItemUnitCost}" />
                            <TextBox Grid.Column="4" materialDesign:HintAssist.Hint="Lote"
                                     Text="{Binding ItemLot}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0" materialDesign:HintAssist.Hint="Validade"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                        SelectedDate="{Binding ItemExpiration}" Margin="0,0,0,12" />
                            <Button Grid.Column="2" Command="{Binding AddItemCommand}" VerticalAlignment="Center"
                                    Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                                    <TextBlock Text="ADICIONAR" Margin="6,0,0,0" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <DataGrid ItemsSource="{Binding EditorItems}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" MaxHeight="240" Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="Qtde" Binding="{Binding Quantity, StringFormat=N2}" Width="70" IsReadOnly="True" />
                                <DataGridTextColumn Header="Custo" Binding="{Binding UnitCost, StringFormat=C2}" Width="90" IsReadOnly="True" />
                                <DataGridTextColumn Header="Lote" Binding="{Binding LotNumber}" Width="80" IsReadOnly="True" />
                                <DataGridTextColumn Header="Validade" Binding="{Binding ExpirationDate, StringFormat=dd/MM/yyyy}" Width="90" IsReadOnly="True" />
                                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C2}" Width="90" IsReadOnly="True" />
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="4"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Delete" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
