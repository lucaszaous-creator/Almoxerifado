<UserControl x:Class="ALMOXPRO.UI.Views.RequisitionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12" LastChildFill="False">
                <TextBox Width="240" materialDesign:HintAssist.Hint="Pesquisar por número ou solicitante"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:TextFieldAssist.HasClearButton="True">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchRequisitionsCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <ComboBox Width="140" Margin="8,0,0,0" materialDesign:HintAssist.Hint="Situação"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding StatusFilter}" />
                <Button Margin="8,0,0,0" Command="{Binding SearchRequisitionsCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Magnify" />
                </Button>

                <Button DockPanel.Dock="Right" Command="{Binding NewCommand}" VerticalAlignment="Center"
                        Visibility="{Binding CanCreate, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                        <TextBlock Text="NOVA REQUISIÇÃO" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding CancelRequisitionCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        Visibility="{Binding CanFulfill, Converter={StaticResource BoolToVis}}"
                        ToolTip="Cancelar requisição pendente">
                    <materialDesign:PackIcon Kind="Close" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding FulfillCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        Visibility="{Binding CanFulfill, Converter={StaticResource BoolToVis}}"
                        ToolTip="Atender: gera a saída de estoque vinculada">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckAll" VerticalAlignment="Center" />
                        <TextBlock Text="ATENDER" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding PrintCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        ToolTip="Imprimir documento para assinatura">
                    <materialDesign:PackIcon Kind="Printer" />
                </Button>
            </DockPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding PreviousPageCommand}">
                    <materialDesign:PackIcon Kind="ChevronLeft" />
                </Button>
                <TextBlock VerticalAlignment="Center" Margin="8,0">
                    <Run Text="{Binding Page}" /><Run Text=" / " /><Run Text="{Binding TotalPages}" />
                </TextBlock>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NextPageCommand}">
                    <materialDesign:PackIcon Kind="ChevronRight" />
                </Button>
            </StackPanel>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Número" Binding="{Binding Number}" Width="110" />
                        <DataGridTextColumn Header="Situação" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Setor" Binding="{Binding SectorName}" Width="140" />
                        <DataGridTextColumn Header="Solicitante" Binding="{Binding RequesterName}" Width="140" />
                        <DataGridTextColumn Header="Funcionário" Binding="{Binding EmployeeName}" Width="140" />
                        <DataGridTextColumn Header="Almoxarifado" Binding="{Binding WarehouseName}" Width="*" />
                        <DataGridTextColumn Header="Data" Binding="{Binding RequestDate, StringFormat=dd/MM/yyyy HH:mm}" Width="130" />
                        <DataGridTextColumn Header="Atendida em" Binding="{Binding FulfilledAt, StringFormat=dd/MM/yyyy HH:mm}" Width="130" />
                        <DataGridTextColumn Header="Saída" Binding="{Binding ExitNumber}" Width="100" />
                        <DataGridTextColumn Header="Itens" Binding="{Binding ItemCount}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Text="Nenhuma requisição por aqui. Clique em NOVA REQUISIÇÃO para registrar o primeiro pedido de um setor."
                           HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" TextWrapping="Wrap"
                           Visibility="{Binding Items.Count, Converter={StaticResource ZeroToVis}}" />
                </Grid>

                <TextBlock Grid.Row="1" Text="Itens da requisição selecionada" FontWeight="SemiBold" Margin="0,12,0,4" />

                <DataGrid Grid.Row="2" ItemsSource="{Binding SelectedItems}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding InternalCode}" Width="100" />
                        <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*" />
                        <DataGridTextColumn Header="Un." Binding="{Binding Unit}" Width="60" />
                        <DataGridTextColumn Header="Solicitado" Binding="{Binding QuantityRequested, StringFormat=N2}" Width="100" />
                        <DataGridTextColumn Header="Entregue" Binding="{Binding QuantityFulfilled, StringFormat=N2}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </DockPanel>

        <!-- Painel de atendimento (total ou parcial) -->
        <Border HorizontalAlignment="Right" Width="560"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsFulfillOpen, Converter={StaticResource BoolToVis}}"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="Atender Requisição" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,16" TextWrapping="Wrap"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Text="Ajuste a coluna 'Entregar agora' para entrega parcial — o saldo não entregue continua pendente." />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="CANCELAR" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CloseFulfillCommand}" Margin="0,0,8,0" />
                    <Button Content="CONFIRMAR ENTREGA" Command="{Binding ConfirmFulfillCommand}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding FulfillItems}" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Solicitado" Binding="{Binding Requested, StringFormat=N2}" Width="85" IsReadOnly="True" />
                        <DataGridTextColumn Header="Entregue" Binding="{Binding AlreadyFulfilled, StringFormat=N2}" Width="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Pendente" Binding="{Binding Remaining, StringFormat=N2}" Width="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Entregar agora" Binding="{Binding DeliverNow, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border HorizontalAlignment="Right" Width="560"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVis}}"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="Nova Requisição de Materiais" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,16" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="CANCELAR" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CancelEditCommand}" Margin="0,0,8,0" />
                    <Button Content="REGISTRAR REQUISIÇÃO" Command="{Binding ConfirmCommand}" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                <Setter Property="Margin" Value="0,0,0,12" />
                            </Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                                <Setter Property="Margin" Value="0,0,0,12" />
                            </Style>
                        </StackPanel.Resources>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" materialDesign:HintAssist.Hint="Setor solicitante *"
                                      ItemsSource="{Binding Sectors}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedSector}" />
                            <ComboBox Grid.Column="2" materialDesign:HintAssist.Hint="Almoxarifado *"
                                      ItemsSource="{Binding Warehouses}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedWarehouse}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" materialDesign:HintAssist.Hint="Funcionário que retira"
                                      ItemsSource="{Binding Employees}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedEmployee}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Ou nome de quem retira"
                                     Text="{Binding RequesterName}" />
                        </Grid>
                        <TextBox materialDesign:HintAssist.Hint="Observações" Text="{Binding Notes}" />

                        <Separator Margin="0,4,0,12" />
                        <TextBlock Text="Itens" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="Código interno ou código de barras"
                                     Text="{Binding ItemCode, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding FindProductCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2" Command="{Binding FindProductCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                                    Margin="0,0,0,12" ToolTip="Localizar produto">
                                <materialDesign:PackIcon Kind="BarcodeScan" />
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding FoundProduct.Name}" FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Quantidade"
                                     Text="{Binding ItemQuantity}" />
                            <Button Grid.Column="2" Command="{Binding AddItemCommand}" VerticalAlignment="Center"
                                    Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                                    <TextBlock Text="ADICIONAR" Margin="6,0,0,0" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <DataGrid ItemsSource="{Binding EditorItems}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" MaxHeight="240" Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="Qtde" Binding="{Binding Quantity, StringFormat=N2}" Width="80" IsReadOnly="True" />
                                <DataGridTextColumn Header="Disponível" Binding="{Binding Available, StringFormat=N2}" Width="100" IsReadOnly="True" />
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="4"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Delete" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
