<Window x:Class="ALMOXPRO.UI.Views.DatabaseConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ALMOX PRO - Banco de Dados"
        Height="640" Width="440"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Border Background="{DynamicResource MaterialDesignPaper}" CornerRadius="12"
            BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
            MouseLeftButtonDown="OnDragWindow">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,16,0,24">
                <materialDesign:PackIcon Kind="Database" Width="56" Height="56"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}" />
                <TextBlock Text="Conexão com o banco" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="Informe os dados do servidor PostgreSQL" FontSize="13" Opacity="0.6"
                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Servidor (host)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Porta"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBox materialDesign:HintAssist.Hint="Banco de dados"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />
                <TextBox materialDesign:HintAssist.Hint="Usuário"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />
                <PasswordBox x:Name="PasswordInput"
                             materialDesign:HintAssist.Hint="Senha"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             PasswordChanged="OnPasswordChanged"
                             Margin="0,0,0,12" />
                <CheckBox IsChecked="{Binding UseSsl}" Margin="0,0,0,8"
                          ToolTip="Marque para bancos hospedados na nuvem, que exigem conexão criptografada.">
                    <TextBlock TextWrapping="Wrap"
                               Text="Conexão segura (SSL) — banco em nuvem (Neon, Supabase, RDS...)" />
                </CheckBox>

                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" MinHeight="36" Margin="0,4" />

                <Button Content="TESTAR CONEXÃO" Height="40"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding TestConnectionCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Margin="0,0,0,8" />
                <Button Content="SALVAR E CONTINUAR" Height="44"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </StackPanel>

            <Button Grid.Row="2" Content="Sair" HorizontalAlignment="Center"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding CancelCommand}" />
        </Grid>
    </Border>
</Window>
