<UserControl x:Class="ALMOXPRO.UI.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12" LastChildFill="False">
                <TextBlock Text="Categorias e Subcategorias" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right" Command="{Binding NewCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                        <TextBlock Text="NOVA CATEGORIA" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding DeleteCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}">
                    <materialDesign:PackIcon Kind="Delete" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding EditCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}">
                    <materialDesign:PackIcon Kind="Pencil" />
                </Button>
            </DockPanel>

            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Categoria pai" Binding="{Binding ParentName}" Width="200" />
                    <DataGridTextColumn Header="Descrição" Binding="{Binding Description}" Width="2*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border HorizontalAlignment="Right" Width="400"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVis}}"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <StackPanel Margin="20">
                <TextBlock Text="Categoria" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                <TextBox materialDesign:HintAssist.Hint="Nome *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Editor.Name}" Margin="0,0,0,12" />
                <TextBox materialDesign:HintAssist.Hint="Descrição"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Editor.Description}" Margin="0,0,0,12" />
                <ComboBox materialDesign:HintAssist.Hint="Categoria pai (opcional, cria subcategoria)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding ParentOptions}" DisplayMemberPath="Name"
                          SelectedValuePath="Id" SelectedValue="{Binding Editor.ParentId}"
                          materialDesign:TextFieldAssist.HasClearButton="True" Margin="0,0,0,16" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="CANCELAR" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CancelEditCommand}" Margin="0,0,8,0" />
                    <Button Content="SALVAR" Command="{Binding SaveCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
