<Window x:Class="ALMOXPRO.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ALMOX PRO - Login"
        Height="560" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Border Background="{DynamicResource MaterialDesignPaper}" CornerRadius="12"
            BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
            MouseLeftButtonDown="OnDragWindow">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,16,0,24">
                <materialDesign:PackIcon Kind="Warehouse" Width="56" Height="56"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}" />
                <TextBlock Text="ALMOX PRO" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="Gestão de Almoxarifado" FontSize="13" Opacity="0.6" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Login -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center"
                        Visibility="{Binding IsRecoveryMode, Converter={StaticResource InverseBoolToVis}}">
                <TextBox materialDesign:HintAssist.Hint="Usuário"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />
                <PasswordBox x:Name="PasswordInput"
                             materialDesign:HintAssist.Hint="Senha"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             KeyDown="OnPasswordKeyDown"
                             Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" TextWrapping="Wrap"
                           MinHeight="20" Margin="0,4" />
                <Button Content="ENTRAR" Height="44"
                        Command="{Binding SignInCommand}"
                        CommandParameter="{Binding ElementName=PasswordInput}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                <Button Content="Esqueci minha senha"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding ToggleRecoveryCommand}" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Recuperação de senha -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center"
                        Visibility="{Binding IsRecoveryMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Recuperar senha" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TextBox materialDesign:HintAssist.Hint="Login ou e-mail"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding RecoveryLoginOrEmail, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8" />
                <Button Content="GERAR CÓDIGO" Height="40"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding RequestRecoveryCommand}" Margin="0,0,0,16" />
                <TextBox materialDesign:HintAssist.Hint="Código de recuperação"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding RecoveryToken, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8" />
                <PasswordBox x:Name="NewPasswordInput"
                             materialDesign:HintAssist.Hint="Nova senha"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" TextWrapping="Wrap"
                           MinHeight="20" Margin="0,4" />
                <Button Content="REDEFINIR SENHA" Height="40"
                        Command="{Binding ResetPasswordCommand}"
                        CommandParameter="{Binding ElementName=NewPasswordInput}" />
                <Button Content="Voltar ao login"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding ToggleRecoveryCommand}" Margin="0,8,0,0" />
            </StackPanel>

            <Button Grid.Row="2" Content="Sair" HorizontalAlignment="Center"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding ExitCommand}" />
        </Grid>
    </Border>
</Window>
