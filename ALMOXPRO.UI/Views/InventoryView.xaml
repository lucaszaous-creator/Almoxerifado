<UserControl x:Class="ALMOXPRO.UI.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12" LastChildFill="False">
                <ComboBox Width="160" materialDesign:HintAssist.Hint="Tipo"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding InventoryTypes}" SelectedItem="{Binding NewType}" />
                <ComboBox Width="220" Margin="8,0,0,0" materialDesign:HintAssist.Hint="Almoxarifado"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding Warehouses}" DisplayMemberPath="Name"
                          SelectedItem="{Binding NewWarehouse}" />
                <Button Margin="8,0,0,0" Command="{Binding OpenInventoryCommand}" VerticalAlignment="Center"
                        Visibility="{Binding CanExecute, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                        <TextBlock Text="ABRIR INVENTÁRIO" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>

                <Button DockPanel.Dock="Right" Command="{Binding StartCountingCommand}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        Visibility="{Binding CanExecute, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BarcodeScan" VerticalAlignment="Center" />
                        <TextBlock Text="CONTAGEM" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding CancelInventoryCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        ToolTip="Cancelar inventário">
                    <materialDesign:PackIcon Kind="Close" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding FinishCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        ToolTip="Concluir inventário">
                    <materialDesign:PackIcon Kind="CheckAll" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Refresh" />
                </Button>
            </DockPanel>

            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Número" Binding="{Binding Number}" Width="110" />
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="100" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                    <DataGridTextColumn Header="Almoxarifado" Binding="{Binding WarehouseName}" Width="*" />
                    <DataGridTextColumn Header="Início" Binding="{Binding StartedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="140" />
                    <DataGridTextColumn Header="Conclusão" Binding="{Binding FinishedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="140" />
                    <DataGridTextColumn Header="Itens" Binding="{Binding ItemCount}" Width="60" />
                    <DataGridTextColumn Header="Contados" Binding="{Binding CountedItems}" Width="80" />
                    <DataGridTextColumn Header="Diferenças" Binding="{Binding ItemsWithDifference}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Painel de contagem -->
        <Border HorizontalAlignment="Right" Width="720"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsCountingOpen, Converter={StaticResource BoolToVis}}"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="Conferência de Inventário" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,16" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="FECHAR" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CloseCountingCommand}" Margin="0,0,8,0" />
                    <Button Command="{Binding ApplyAdjustmentsCommand}"
                            Visibility="{Binding CanAdjust, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Scale" VerticalAlignment="Center" />
                            <TextBlock Text="APLICAR AJUSTES" Margin="6,0,0,0" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <DockPanel>
                    <!-- Leitura por código de barras / QR Code -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Leia o código de barras ou QR Code"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ScanCode, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ScanCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Qtde"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ScanQuantity}" />
                        <Button Grid.Column="4" Command="{Binding ScanCommand}" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="BarcodeScan" />
                        </Button>
                    </Grid>

                    <!-- Contagem manual do item selecionado -->
                    <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Quantidade contada (item selecionado)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ManualQuantity}" />
                        <Button Grid.Column="2" Command="{Binding RegisterManualCountCommand}" VerticalAlignment="Center"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                IsEnabled="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}">
                            <TextBlock Text="REGISTRAR CONTAGEM" />
                        </Button>
                    </Grid>

                    <DataGrid ItemsSource="{Binding CountItems}" SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Binding="{Binding InternalCode}" Width="90" />
                            <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="Lote" Binding="{Binding LotNumber}" Width="80" />
                            <DataGridTextColumn Header="Sistema" Binding="{Binding SystemQuantity, StringFormat=N2}" Width="80" />
                            <DataGridTextColumn Header="Contado" Binding="{Binding CountedQuantity, StringFormat=N2}" Width="80" />
                            <DataGridTextColumn Header="Diferença" Binding="{Binding Difference, StringFormat=N2}" Width="90" />
                            <DataGridCheckBoxColumn Header="Ajustado" Binding="{Binding Adjusted}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
