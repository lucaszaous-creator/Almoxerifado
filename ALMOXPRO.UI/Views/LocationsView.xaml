<UserControl x:Class="ALMOXPRO.UI.Views.LocationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12" LastChildFill="False">
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Refresh" />
                </Button>

                <Button DockPanel.Dock="Right" Command="{Binding NewCommand}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                        <TextBlock Text="NOVA LOCALIZAÇÃO" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding DeleteCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}">
                    <materialDesign:PackIcon Kind="Delete" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding EditCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}">
                    <materialDesign:PackIcon Kind="Pencil" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding PrintLabelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        ToolTip="Gerar etiqueta com QR Code da localização">
                    <materialDesign:PackIcon Kind="Qrcode" />
                </Button>
            </DockPanel>

            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="180" />
                    <DataGridTextColumn Header="Almoxarifado" Binding="{Binding WarehouseName}" Width="*" />
                    <DataGridTextColumn Header="Prédio" Binding="{Binding Building}" Width="110" />
                    <DataGridTextColumn Header="Andar" Binding="{Binding Floor}" Width="80" />
                    <DataGridTextColumn Header="Corredor" Binding="{Binding Corridor}" Width="90" />
                    <DataGridTextColumn Header="Estante" Binding="{Binding Shelf}" Width="80" />
                    <DataGridTextColumn Header="Prateleira" Binding="{Binding Rack}" Width="90" />
                    <DataGridTextColumn Header="Posição" Binding="{Binding Position}" Width="80" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border HorizontalAlignment="Right" Width="420"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVis}}"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="Cadastro de Localização" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,16" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="CANCELAR" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CancelEditCommand}" Margin="0,0,8,0" />
                    <Button Content="SALVAR" Command="{Binding SaveCommand}" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                <Setter Property="Margin" Value="0,0,0,12" />
                            </Style>
                        </StackPanel.Resources>
                        <ComboBox materialDesign:HintAssist.Hint="Almoxarifado *"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding Warehouses}" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" SelectedValue="{Binding Editor.WarehouseId}"
                                  Margin="0,0,0,12" />
                        <TextBox materialDesign:HintAssist.Hint="Prédio *" Text="{Binding Editor.Building}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Andar" Text="{Binding Editor.Floor}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Corredor" Text="{Binding Editor.Corridor}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Estante" Text="{Binding Editor.Shelf}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Prateleira" Text="{Binding Editor.Rack}" />
                            <TextBox Grid.Column="4" materialDesign:HintAssist.Hint="Posição" Text="{Binding Editor.Position}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
