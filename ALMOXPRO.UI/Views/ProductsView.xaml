<UserControl x:Class="ALMOXPRO.UI.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <!-- Lista -->
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12" LastChildFill="False">
                <TextBox Width="320" materialDesign:HintAssist.Hint="Pesquisar por nome, código ou código de barras"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:TextFieldAssist.HasClearButton="True">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchProductsCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Margin="8,0,0,0" Command="{Binding SearchProductsCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Magnify" />
                </Button>

                <Button DockPanel.Dock="Right" Command="{Binding NewCommand}" VerticalAlignment="Center"
                        Visibility="{Binding CanCreate, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                        <TextBlock Text="NOVO PRODUTO" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding PrintLabelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        ToolTip="Gerar etiqueta com código de barras e QR Code">
                    <materialDesign:PackIcon Kind="Barcode" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding DeleteCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}">
                    <materialDesign:PackIcon Kind="Delete" />
                </Button>
                <Button DockPanel.Dock="Right" Margin="0,0,8,0" Command="{Binding EditCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"
                        IsEnabled="{Binding Selected, Converter={StaticResource NotNullToBool}}"
                        Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}}">
                    <materialDesign:PackIcon Kind="Pencil" />
                </Button>
            </DockPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding PreviousPageCommand}">
                    <materialDesign:PackIcon Kind="ChevronLeft" />
                </Button>
                <TextBlock VerticalAlignment="Center" Margin="8,0">
                    <Run Text="{Binding Page}" /><Run Text=" / " /><Run Text="{Binding TotalPages}" />
                </TextBlock>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NextPageCommand}">
                    <materialDesign:PackIcon Kind="ChevronRight" />
                </Button>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding InternalCode}" Width="100" />
                    <DataGridTextColumn Header="Cód. Barras" Binding="{Binding Barcode}" Width="120" />
                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Categoria" Binding="{Binding CategoryName}" Width="140" />
                    <DataGridTextColumn Header="Un." Binding="{Binding Unit}" Width="50" />
                    <DataGridTextColumn Header="Estoque" Binding="{Binding CurrentStock, StringFormat=N2}" Width="90" />
                    <DataGridTextColumn Header="Mínimo" Binding="{Binding MinStock, StringFormat=N2}" Width="80" />
                    <DataGridTextColumn Header="Custo Médio" Binding="{Binding AverageCost, StringFormat=C2}" Width="110" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Editor (drawer) -->
        <Border HorizontalAlignment="Right" Width="480"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVis}}"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="Cadastro de Produto" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,16" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="CANCELAR" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CancelEditCommand}" Margin="0,0,8,0" />
                    <Button Content="SALVAR" Command="{Binding SaveCommand}" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                <Setter Property="Margin" Value="0,0,0,12" />
                            </Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                                <Setter Property="Margin" Value="0,0,0,12" />
                            </Style>
                        </StackPanel.Resources>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Código interno *"
                                     Text="{Binding Editor.InternalCode}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Código de barras"
                                     Text="{Binding Editor.Barcode}" />
                        </Grid>
                        <TextBox materialDesign:HintAssist.Hint="Nome *" Text="{Binding Editor.Name}" />
                        <TextBox materialDesign:HintAssist.Hint="Descrição" Text="{Binding Editor.Description}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                        <ComboBox materialDesign:HintAssist.Hint="Categoria *"
                                  ItemsSource="{Binding Categories}" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" SelectedValue="{Binding Editor.CategoryId}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Marca"
                                     Text="{Binding Editor.Brand}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Fabricante"
                                     Text="{Binding Editor.Manufacturer}" />
                        </Grid>
                        <ComboBox materialDesign:HintAssist.Hint="Fornecedor principal"
                                  ItemsSource="{Binding Suppliers}" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" SelectedValue="{Binding Editor.MainSupplierId}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" materialDesign:HintAssist.Hint="Unidade *"
                                      ItemsSource="{Binding Units}" SelectedItem="{Binding Editor.Unit}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Peso (kg)"
                                     Text="{Binding Editor.Weight}" />
                            <TextBox Grid.Column="4" materialDesign:HintAssist.Hint="Dimensões"
                                     Text="{Binding Editor.Dimensions}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Estoque mínimo"
                                     Text="{Binding Editor.MinStock}" />
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Estoque máximo"
                                     Text="{Binding Editor.MaxStock}" />
                        </Grid>
                        <ComboBox materialDesign:HintAssist.Hint="Localização padrão"
                                  ItemsSource="{Binding Locations}" DisplayMemberPath="Code"
                                  SelectedValuePath="Id" SelectedValue="{Binding Editor.DefaultLocationId}" />
                        <TextBox materialDesign:HintAssist.Hint="Patrimônio" Text="{Binding Editor.AssetNumber}" />
                        <TextBox materialDesign:HintAssist.Hint="Observações" Text="{Binding Editor.Notes}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />

                        <WrapPanel Margin="0,4,0,8">
                            <CheckBox Content="Controlado" IsChecked="{Binding Editor.IsControlled}" Margin="0,0,16,8" />
                            <CheckBox Content="Perecível" IsChecked="{Binding Editor.IsPerishable}" Margin="0,0,16,8" />
                            <CheckBox Content="Controla validade" IsChecked="{Binding Editor.TracksExpiration}" Margin="0,0,16,8" />
                            <CheckBox Content="Controla lote" IsChecked="{Binding Editor.TracksLot}" Margin="0,0,16,8" />
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
